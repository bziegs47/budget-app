{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mimo",
  "version": "0.1.0",
  "identifier": "com.bziegs.mimo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1180,
        "height": 820
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Finance",
    "shortDescription": "Money In, Money Out — local-first desktop budget app",
    "longDescription": "mimo is a local-first desktop budget app for macOS. Track income and expenses by month, compare years, and export your data. All data stays on your machine in .mimo files.",
    "copyright": "© 2025 bziegs",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
